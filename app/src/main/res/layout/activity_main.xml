<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_alignParentTop="true"
        android:progressTint="@color/green_primary"
        android:progressBackgroundTint="@android:color/transparent"
        android:max="100"
        android:visibility="gone" />

    <!-- Network status banner -->
    <TextView
        android:id="@+id/tvNetworkStatus"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_below="@id/progressBar"
        android:background="#F57C00"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:text="Koneksi tidak stabil"
        android:visibility="gone" />

    <!-- SwipeRefresh + WebView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/progressBar">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- No Internet Screen -->
    <RelativeLayout
        android:id="@+id/noInternetLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_centerInParent="true"
            android:padding="32dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="📡"
                android:textSize="42sp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tidak Ada Koneksi"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#202124"
                android:layout_marginTop="18dp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Periksa koneksi internet kamu lalu coba lagi"
                android:textSize="14sp"
                android:textColor="#5f6368"
                android:layout_marginTop="8dp"
                android:gravity="center" />

            <Button
                android:id="@+id/btnRetry"
                android:layout_width="180dp"
                android:layout_height="48dp"
                android:text="Coba Lagi"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/green_primary"
                android:layout_marginTop="28dp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>
